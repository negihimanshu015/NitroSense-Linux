{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nitrosense-linux",
  "version": "0.1.0",
  "identifier": "com.thephenominal.nitrosense-linux",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "nitrosense-linux",
        "width": 960,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
